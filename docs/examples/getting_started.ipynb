     "iopub.status.idle": "2026-01-28T15:36:16.955288Z",
     "shell.execute_reply": "2026-01-28T15:36:16.954836Z",
     "shell.execute_reply.started": "2026-01-28T15:36:16.811648Z"
    }
   },
   "outputs": [],
   "source": [
    "ds.allocate()"
   ]
  },
